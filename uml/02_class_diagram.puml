@startuml class_diagram
title Оценка PRO — Диаграмма классов

skinparam classAttributeIconSize 0
skinparam backgroundColor #F8FAFC
skinparam class {
  BackgroundColor #FFFFFF
  BorderColor #2A6FDB
  HeaderBackgroundColor #2A6FDB
  HeaderFontColor #FFFFFF
}

enum StatusEnum {
  НОВАЯ
  ДОКУМЕНТЫ
  АНАЛОГИ
  РАСЧЕТ
  ПРОВЕРКА
  ГОТОВА
}

enum ApproachType {
  СРАВНИТЕЛЬНЫЙ
  ДОХОДНЫЙ
  ЗАТРАТНЫЙ
}

enum ClientType {
  ЮР_ЛИЦО
  ФИЗ_ЛИЦО
}

class Заявка {
  +id: String
  +объект: String
  +адрес: String
  +тип: String
  +статус: StatusEnum
  +датаОценки: Date
  +ответственный: String
  --
  +создать(): void
  +обновитьСтатус(s: StatusEnum): void
  +назначитьОценщика(a: Оценщик): void
}

class ОбъектОценки {
  +id: String
  +название: String
  +адрес: String
  +тип: String
  +площадь: Float
  +этажность: String
  +годПостройки: Int
  +кадастровый: String
  +целоценки: String
  +видСтоимости: String
  +клиент: String
  --
  +сохранить(): void
  +загрузитьДокументы(docs: List): void
}

class Аналог {
  +id: String
  +адрес: String
  +полныйАдрес: String
  +источник: String
  +ссылка: URL
  +активен: Boolean
  +цена: Long
  +площадь: Float
  +ценаМ2: Long
  +расстояние: Float
  +состояние: String
  +этажей: Int
  +годПостройки: Int
  +материалСтен: String
  +описание: String
  --
  +активировать(): void
  +деактивировать(): void
  +рассчитатьСкорр(): Long
}

class Поправка {
  +фактор: String
  +значение: Float
}

class Расчет {
  +подход: ApproachType
  +стоимость: Long
  +вес: Int
  +применяется: Boolean
  +примечание: String
  --
  +пересчитать(): void
  +установитьВес(w: Int): void
}

class СравнительныйРасчет {
  +строкиАналогов: List<СтрокаАналога>
  --
  +рассчитать(): Long
  +получитьВилку(): Range
}

class СтрокаАналога {
  +аналог: Аналог
  +вес: Float
  +поправкаТорг: Float
  +поправкаЛок: Float
  +поправкаРемонт: Float
  +поправкаЭтаж: Float
  --
  +скорректированнаяЦена(): Long
}

class ДоходныйРасчет {
  +площадь: Float
  +ставкаАренды: Long
  +недозагрузка: Float
  +операцРасходы: Float
  +ставкаКапит: Float
  --
  +pgi(): Long
  +egi(): Long
  +noi(): Long
  +рассчитать(): Long
}

class ЗатратныйРасчет {
  +площадь: Float
  +стоимостьЗамещМ2: Long
  +физИзнос: Float
  +функцУстар: Float
  +внешнУстар: Float
  --
  +стоимостьЗамещ(): Long
  +совокупныйИзнос(): Float
  +рассчитать(): Long
}

class СогласованиеРезультатов {
  +итоговаяСтоимость: Long
  +диапазонМин: Long
  +диапазонМакс: Long
  +датаРасчета: Date
  --
  +вычислить(расчеты: List<Расчет>): void
}

class ПроверкаФСО {
  +элементы: List<ЭлементЧеклиста>
  --
  +процентСоответствия(): Int
  +проверить(): void
  +готовКОтчету(): Boolean
}

class ЭлементЧеклиста {
  +название: String
  +выполнено: Boolean
  --
  +переключить(): void
}

class Отчет {
  +номер: String
  +объем: Int
  +форматы: List<String>
  +датаФормирования: Date
  --
  +сформировать(): void
  +экспортировать(формат: String): File
  +отправитьНаПроверку(): void
}

class Клиент {
  +имя: String
  +тип: ClientType
  +контакт: String
  +заказов: Int
  --
  +добавить(): void
  +получитьИсторию(): List<Заявка>
}

class Оценщик {
  +имя: String
  +роль: String
  +инициалы: String
  +номерСРО: String
  +организация: String
  +email: String
}

class АналитикаРынка {
  +база: List<ОбъектАналитики>
  --
  +фильтровать(f: Фильтр): List<ОбъектАналитики>
  +среднееМ2(): Long
  +медианаМ2(): Long
  +группироватьПо(поле: String): Map
}

class ОбъектАналитики {
  +id: String
  +адрес: String
  +район: String
  +линия: String
  +класс: String
  +эпоха: String
  +тип: String
  +серия: String
  +этажность: Int
  +материалСтен: String
  +состояние: String
  +типИспользования: String
  +площадь: Float
  +цена: Long
  +ценаМ2: Long
  +арендаМ2: Long
  +год: Int
}

Заявка "1" *-- "1" ОбъектОценки
Заявка "1" *-- "0..*" Аналог
Заявка "1" *-- "1..*" Расчет
Заявка "1" *-- "1" ПроверкаФСО
Заявка "1" *-- "1" Отчет
Заявка "*" --> "1" Клиент
Заявка "*" --> "1" Оценщик
Заявка --> StatusEnum

Аналог "1" *-- "0..*" Поправка

Расчет <|-- СравнительныйРасчет
Расчет <|-- ДоходныйРасчет
Расчет <|-- ЗатратныйРасчет
Расчет --> ApproachType

СравнительныйРасчет "1" *-- "1..*" СтрокаАналога
СтрокаАналога --> Аналог

Расчет "1..*" --> "1" СогласованиеРезультатов

ПроверкаФСО "1" *-- "1..*" ЭлементЧеклиста

Клиент --> ClientType

АналитикаРынка "1" *-- "0..*" ОбъектАналитики

@enduml
