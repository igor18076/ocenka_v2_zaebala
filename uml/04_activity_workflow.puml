@startuml activity_workflow
title Оценка PRO — Диаграмма деятельности: Рабочий процесс оценки

skinparam backgroundColor #F8FAFC
skinparam activityBackgroundColor #FFFFFF
skinparam activityBorderColor #2A6FDB
skinparam activityStartColor #2A6FDB
skinparam activityEndColor #25A871

|#EFF6FF|Клиент|
|#F0FDF4|Оценщик|
|#FFF7ED|Система|

|Клиент|
start
:Обращение с запросом на оценку\nобъекта недвижимости;

|Оценщик|
:Создать заявку в системе\n(тип объекта, клиент, вид стоимости);

|Система|
:Присвоить статус «НОВАЯ»\nГенерировать номер ОЗ-XXXX;

|Оценщик|
:Назначить ответственного оценщика;
:Загрузить правоустанавливающие документы\n(ЕГРН, тех.паспорт, договор, кадастр.план);
:Заполнить параметры объекта оценки\n(тип, площадь, год, этажность, кадастровый №);

|Система|
:Статус: «ДОКУМЕНТЫ»;

|Оценщик|
:Запустить подбор аналогов;

|Система|
fork
  :Поиск в ЦИАН;
fork again
  :Поиск в Авито;
fork again
  :Поиск в Domclick;
end fork
:Формирование выборки аналогов\n(фильтр по типу, радиусу, площади);
:Статус: «АНАЛОГИ»;

|Оценщик|
repeat
  :Открыть карточку аналога\n(фото, ссылка, характеристики);
  :Проверить активность объявления;
  if (Объявление актуально?) then (нет)
    :Отметить как снятое;
  else (да)
  endif
  :Установить поправки\n(торг, локация, состояние, этаж);
repeat while (Проверены все аналоги?) is (нет) not (да)

if (Достаточно аналогов?) then (нет)
  :Добавить аналоги вручную;
else (да)
endif

:Перейти к расчёту стоимости;

|Система|
:Статус: «РАСЧЁТ»;

|Оценщик|
fork
  :Сравнительный подход\nРедактировать аналоги, веса, поправки;
fork again
  if (Объект коммерческий?) then (да)
    :Доходный подход\nАренда, NOI, ставка капит.;
  else (нет)
    :Доходный подход отключён;
  endif
fork again
  :Затратный подход\nСтоимость замещения, виды износа;
end fork

:Согласование результатов по весам\n(сумма весов = 100%);
:Итоговая рыночная стоимость;

|Система|
:Проверка по чек-листу ФСО;

|Оценщик|
if (Все требования ФСО выполнены?) then (нет)
  :Доработать разделы отчёта;
  |Система|
  :Повторная проверка ФСО;
  |Оценщик|
else (да)
endif

|Система|
:Статус: «ПРОВЕРКА»;

|Оценщик|
:Сформировать отчёт об оценке;

|Система|
:Генерация документа DOCX (48+ стр.)\nФормирование PDF-версии;
:Статус: «ГОТОВА»;

|Оценщик|
:Передать отчёт клиенту;

|Клиент|
:Получить и подписать отчёт об оценке;
stop

@enduml
