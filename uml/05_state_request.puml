@startuml state_request
title Оценка PRO — Диаграмма состояний: Жизненный цикл заявки

skinparam backgroundColor #F8FAFC
skinparam state {
  BackgroundColor #FFFFFF
  BorderColor #2A6FDB
  FontColor #1e293b
  StartColor #2A6FDB
  EndColor #25A871
}

[*] --> НОВАЯ : Заявка создана\nКлиентом / оценщиком

state НОВАЯ {
  НОВАЯ : Ответственный не назначен
  НОВАЯ : Документы отсутствуют
  НОВАЯ : Бейдж: badge=6 (входящие)
}

НОВАЯ --> ДОКУМЕНТЫ : Назначен ответственный оценщик\nНачата загрузка документов

state ДОКУМЕНТЫ {
  ДОКУМЕНТЫ : Загрузка ЕГРН
  ДОКУМЕНТЫ : Технический паспорт
  ДОКУМЕНТЫ : Договор купли-продажи
  ДОКУМЕНТЫ : Кадастровый план участка
  ДОКУМЕНТЫ : Описание параметров объекта
}

ДОКУМЕНТЫ --> АНАЛОГИ : Документы загружены\nОбъект описан → запущен подбор аналогов

state АНАЛОГИ {
  АНАЛОГИ : Поиск: ЦИАН / Авито / Domclick
  АНАЛОГИ : Проверка карточек аналогов
  АНАЛОГИ : Корректировка поправок
  АНАЛОГИ : Отметка снятых объявлений
}

АНАЛОГИ --> РАСЧЕТ : Аналоги подобраны\nи проверены

state РАСЧЕТ {
  state "Сравнительный подход" as COMP
  state "Доходный подход" as INC
  state "Затратный подход" as COST
  state "Согласование" as RECONCILE

  COMP : Редактор аналогов, поправки
  INC  : NOI, ставка капитализации
  COST : Замещение, износ

  [*] --> COMP
  COMP --> INC
  INC --> COST
  COST --> RECONCILE
  RECONCILE --> [*]
}

РАСЧЕТ --> ПРОВЕРКА : Расчёт завершён\nЗапущена проверка ФСО

state ПРОВЕРКА {
  ПРОВЕРКА : Чек-лист ФСО (10 требований)
  ПРОВЕРКА : Выполнено 8/10 → 80%
  ПРОВЕРКА : Доработка недостающих пунктов
  ПРОВЕРКА : Повторная проверка → 100%
}

ПРОВЕРКА --> ГОТОВА : 100% соответствие ФСО\nОтчёт сформирован и готов к выдаче

state ГОТОВА {
  ГОТОВА : DOCX / PDF сформированы
  ГОТОВА : Отчёт отправлен на проверку
  ГОТОВА : Передан клиенту
}

ГОТОВА --> [*] : Заявка закрыта

' Обратные переходы
РАСЧЕТ --> АНАЛОГИ : Недостаточно аналогов\nтребуется дополнение
ПРОВЕРКА --> РАСЧЕТ : Критические замечания\nпо методологии расчёта
ДОКУМЕНТЫ --> НОВАЯ : Отмена назначения\nответственного

@enduml
