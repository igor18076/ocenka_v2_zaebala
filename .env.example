# Required for first database seed (set automatically by `npm run deploy`).
OCENKA_SEED_PASSWORD=replace-with-strong-password

# Public site (leave empty to open by server IP on http://IP/)
# Example: OCENKA_DOMAIN=ocenka.example.com
OCENKA_DOMAIN=

# Email for Let's Encrypt (optional, recommended when OCENKA_DOMAIN is set)
# OCENKA_ACME_EMAIL=you@example.com

# Behind the Caddy proxy TRUST_PROXY should stay true.
OCENKA_TRUST_PROXY=true

# Set true when you open the app only via https://your-domain
# (Secure cookies will not work over plain http://IP)
OCENKA_COOKIE_SECURE=false
